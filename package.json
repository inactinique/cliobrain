{
  "name": "cliobrain",
  "version": "0.1.0",
  "type": "module",
  "description": "Assistant de brainstorming pour historiens - Chat avec vos documents, notes et sources",
  "main": "dist/src/main/index.js",
  "author": {
    "name": "Frédéric Clavert",
    "email": "frederic.clavert@uni.lu"
  },
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:preload\" \"npm run dev:renderer\"",
    "dev:full": "concurrently \"npm run dev:main\" \"npm run dev:preload\" \"npm run dev:renderer\" \"npm run wait-and-start\"",
    "wait-and-start": "sleep 3 && NODE_ENV=development npm start",
    "dev:main": "tsc -p tsconfig.node.json --watch",
    "dev:preload": "tsc -p tsconfig.preload.json --watch",
    "dev:renderer": "vite",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "build:main": "tsc -p tsconfig.node.json --noEmitOnError false && node scripts/fix-imports.mjs && node scripts/fix-backend.mjs",
    "build:preload": "tsc -p tsconfig.preload.json --noEmitOnError false",
    "build:renderer": "vite build",
    "build:all": "npm run build && electron-builder",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "build:win": "npm run build && electron-builder --win",
    "start": "env -u ELECTRON_RUN_AS_NODE npx electron . --no-sandbox",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "clean": "rm -rf dist release",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "chokidar": "^3.6.0",
    "dompurify": "^3.3.1",
    "electron-store": "^10.0.0",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "graphology-layout-forceatlas2": "^0.10.1",
    "hnswlib-node": "^3.0.0",
    "i18next": "^25.7.3",
    "js-yaml": "^4.1.1",
    "lru-cache": "^11.2.4",
    "lucide-react": "^0.562.0",
    "marked": "^17.0.1",
    "natural": "^8.1.0",
    "pdfjs-dist": "^3.11.174",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-error-boundary": "^6.0.2",
    "react-force-graph-2d": "^1.29.0",
    "react-i18next": "^16.5.0",
    "react-resizable-panels": "^2.1.9",
    "tesseract.js": "^7.0.0",
    "zod": "^4.3.5",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.2",
    "@types/better-sqlite3": "^7.6.9",
    "@types/dompurify": "^3.0.5",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.17",
    "concurrently": "^9.2.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.3.0",
    "vite": "^7.3.0",
    "vitest": "^4.0.16"
  },
  "build": {
    "appId": "com.cliobrain.app",
    "productName": "ClioBrain",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*",
      "node_modules/hnswlib-node/**/*"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office",
      "icon": "build/icon.png",
      "executableName": "cliobrain"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
